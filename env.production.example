# ── Database ──────────────────────────────────────────────────────────────────
# If using docker-compose.prod.yml postgres service:
DATABASE_URL="postgresql://marnoa:CHANGE_ME@postgres:5432/maison_marnoa?sslmode=disable"
DIRECT_URL="postgresql://marnoa:CHANGE_ME@postgres:5432/maison_marnoa?sslmode=disable"
# If using Vercel Postgres or external host, replace with your connection strings.

POSTGRES_USER=marnoa
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=maison_marnoa

# ── App URLs ──────────────────────────────────────────────────────────────────
FRONTEND_URL=https://yourdomain.com
BACKEND_URL=https://yourdomain.com
PORT=3000
NODE_ENV=production

# ── Auth ─────────────────────────────────────────────────────────────────────
BETTER_AUTH_SECRET=CHANGE_ME_MIN_32_CHARS_RANDOM_STRING
BETTER_AUTH_URL=https://yourdomain.com/api/auth
BETTER_AUTH_TRUSTED_ORIGINS=https://yourdomain.com

# ── WhatsApp ─────────────────────────────────────────────────────────────────
ADMIN_WHATSAPP_NUMBER=2250102528848

# ── Wave Payment ─────────────────────────────────────────────────────────────
WAVE_API_KEY=
WAVE_MERCHANT_URL=
WAVE_SUCCESS_URL=https://yourdomain.com/order-confirmation
WAVE_ERROR_URL=https://yourdomain.com/checkout

# ── Google OAuth (optional) ──────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── SMTP (use port 465 for TLS, 587 for STARTTLS) ────────────────────────────
SMTP_HOST=smtp.yourdomain.com
SMTP_PORT=465
SMTP_USER=noreply@yourdomain.com
SMTP_PASS=CHANGE_ME
SMTP_FROM=Maison Marnoa <noreply@yourdomain.com>
